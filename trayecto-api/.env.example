# =============================================================================
# trayecto-api — template de variables de entorno
# =============================================================================
# Para dev local: copia este archivo a `.env` y completa los valores.
# `.env` está en .gitignore — nunca lo commitees.
#
# Para producción: estos mismos nombres se configuran en el dashboard de Render
# (Environment tab). Algunos los autorellena el render.yaml; los marcados como
# REQUIRED hay que ponerlos a mano.
# =============================================================================

# --- Postgres (Neon en prod) -------------------------------------------------
# Crear cuenta en https://neon.tech y un proyecto "trayecto". Copiar el
# connection string y separarlo en estas 3 vars. PREFIX la URL con `jdbc:`.
# IMPORTANTE: borrar las credenciales embebidas (usuario:password@) de la URL.
DATABASE_URL=jdbc:postgresql://localhost:5432/trayecto_dev
DATABASE_USER=trayecto
DATABASE_PASSWORD=trayecto

# --- JWT ---------------------------------------------------------------------
# Secret HS256. En prod, Render lo genera con `generateValue: true`.
# Dev: cualquier string >= 32 caracteres está bien.
JWT_SECRET=dev-only-secret-not-for-production-please-set-via-env
JWT_ACCESS_TTL=900       # 15 min
JWT_REFRESH_TTL=2592000  # 30 días

# --- CORS y URL del frontend -------------------------------------------------
# Dev: http://localhost:3000
# Prod: https://trayecto.vercel.app  (URL exacta de Vercel, sin slash final)
CORS_ALLOWED_ORIGINS=http://localhost:3000
APP_URL=http://localhost:3000

# Custom domain compartido — solo si frontend y backend viven en el mismo
# dominio padre (ej. trayecto.app y api.trayecto.app). Si usas *.vercel.app
# + *.onrender.com, dejar VACÍO.
COOKIE_DOMAIN=

# --- Google OAuth 2.0 --------------------------------------------------------
# Consola: https://console.cloud.google.com → APIs & Services → Credentials
# Authorized redirect URI:
#   - Dev:  http://localhost:8080/login/oauth2/code/google
#   - Prod: https://trayecto-api.onrender.com/login/oauth2/code/google
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# --- reCAPTCHA v3 ------------------------------------------------------------
# Crear site en https://www.google.com/recaptcha/admin/create
# La SITE KEY (pública) va al frontend (NEXT_PUBLIC_RECAPTCHA_SITE_KEY).
# La SECRET KEY (privada) va acá.
RECAPTCHA_SECRET_KEY=
RECAPTCHA_MIN_SCORE=0.5

# --- Email (provider selector) -----------------------------------------------
# "smtp" (dev local con Gmail/Brevo) o "resend" (HTTP API, obligatorio en
# Render free porque bloquean SMTP outbound).
APP_MAIL_PROVIDER=smtp

# --- Email - SMTP (dev local, Gmail App Password) ----------------------------
# Solo usado si APP_MAIL_PROVIDER=smtp.
# 1) Activar 2FA en tu cuenta Google.
# 2) https://myaccount.google.com/apppasswords → generar App Password.
# 3) Pegar la app password (16 chars sin espacios) como BREVO_SMTP_KEY.
# Quota Gmail: 500 emails/día. El prefijo "BREVO_" quedó del setup inicial.
BREVO_SMTP_HOST=smtp.gmail.com
BREVO_SMTP_PORT=587
BREVO_SMTP_USER=tu-email@gmail.com
BREVO_SMTP_KEY=

# --- Email - Resend (prod en Render) -----------------------------------------
# Solo usado si APP_MAIL_PROVIDER=resend.
# 1) Crear cuenta gratis en https://resend.com (con GitHub).
# 2) Sidebar → "API Keys" → "+ Create API Key" → Name "Trayecto" → Full access.
# 3) Copiar la key (formato re_XXXX) acá. Quota free: 100 emails/día.
RESEND_API_KEY=

# Remitente. Para portfolio sin dominio propio, usar:
#   "Trayecto <onboarding@resend.dev>"
# Limitación: Resend solo permite enviar al email verificado en tu cuenta.
# Para enviar a cualquiera, verificar un dominio en Resend (requiere comprar uno).
MAIL_FROM=tu-email@gmail.com

# --- Cloudinary (DEPRECATED, mantener vacío) ---------------------------------
# El frontend ahora sube fotos a ImgBB directamente. Estas vars existen por
# compatibilidad con futuro OCR server-side; en prod déjalas vacías.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
